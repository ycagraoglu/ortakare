ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

ConnectionStrings__PostgreSql=Host=postgres;Port=5432;Database=ortakare;Username=ortakare;Password=CHANGE_ME

Jwt__Issuer=Ortakare.Api
Jwt__Audience=Ortakare.Pwa
Jwt__SigningKey=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARACTERS
Jwt__AccessTokenMinutes=30
Jwt__RefreshTokenLifetimeDays=30

Cors__AllowedOrigins__0=https://app.example.com

RateLimiting__AuthPermitLimit=10
RateLimiting__PublicPermitLimit=120
RateLimiting__UploadPermitLimit=30
RateLimiting__OwnerPermitLimit=300
RateLimiting__WindowSeconds=60

PhotoUpload__MaxFileSizeBytes=26214400

ObjectStorage__ServiceUrl=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
ObjectStorage__AccessKey=CHANGE_ME
ObjectStorage__SecretKey=CHANGE_ME
ObjectStorage__BucketName=ortakare-production
ObjectStorage__SignedUrlMinutes=10

Hangfire__Enabled=true
Hangfire__WorkerCount=2
Hangfire__Dashboard__Enabled=false
Hangfire__Dashboard__Path=/operations/jobs
Hangfire__Dashboard__Username=CHANGE_ME
Hangfire__Dashboard__Password=CHANGE_ME_WITH_AT_LEAST_24_CHARACTERS
