{
  "ConnectionStrings": {
    "PostgreSql": "Host=localhost;Port=5432;Database=ortakare;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "Ortakare.Api",
    "Audience": "Ortakare.Pwa",
    "SigningKey": "CHANGE_THIS_DEVELOPMENT_KEY_WITH_AT_LEAST_32_CHARACTERS",
    "AccessTokenMinutes": 30,
    "RefreshTokenLifetimeDays": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "RateLimiting": {
    "AuthPermitLimit": 10,
    "PublicPermitLimit": 120,
    "UploadPermitLimit": 30,
    "OwnerPermitLimit": 300,
    "WindowSeconds": 60
  },
  "PhotoUpload": {
    "MaxFileSizeBytes": 26214400
  },
  "ObjectStorage": {
    "ServiceUrl": "https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com",
    "AccessKey": "SET_WITH_ENVIRONMENT_VARIABLE",
    "SecretKey": "SET_WITH_ENVIRONMENT_VARIABLE",
    "BucketName": "ortakare-production",
    "SignedUrlMinutes": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
